# http = calls iris-api; fixtures = in-browser mock (no backend)
VITE_IRIS_API_MODE=http
VITE_IRIS_API_BASE_URL=http://localhost:8080

# Sentry error reporting (optional). Leave empty to disable; the production
# image bakes this in from the SENTRY_DSN_FRONTEND GitHub Actions secret.
VITE_SENTRY_DSN=
# VITE_SENTRY_RELEASE=
