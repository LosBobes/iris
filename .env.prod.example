# Production environment for the Hetzner deploy (docker-compose.prod.yml).
#
# Copy to `.env` on the server (next to docker-compose.prod.yml) and fill in
# real values. This file is gitignored on the server; never commit the real
# secrets.

# Marks the backend as running in production (secure cookies, etc.).
IRIS_ENV=production

# Session cookie signing secret. REQUIRED — the backend refuses to start
# without it. Generate a long random value:
#   openssl rand -hex 32
IRIS_SESSION_SECRET=

# Same-origin deploy (browser -> Caddy -> nginx -> /api/), so this stays empty.
# Only set it if you serve the API on a different origin.
IRIS_ALLOWED_ORIGINS=

# Optional release identifier tagged onto Sentry events (e.g. the git sha).
IRIS_RELEASE=
